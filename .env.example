# GitHub personal access token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read access to fetch PR data and file contents)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API key
# Get at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: set to "sonnet" to use claude-sonnet-4-6 instead of claude-opus-4-6
# Sonnet is faster and cheaper, useful during development
# ANTHROPIC_MODEL=sonnet
